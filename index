<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Raycharles Kyere — Cybersecurity Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;1,300&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #040a12;
    --surface: #070f1a;
    --card: #0b1623;
    --border: rgba(0,200,255,0.12);
    --accent: #00c8ff;
    --accent2: #00ff9f;
    --accent3: #7b61ff;
    --text: #e8f4f8;
    --muted: #6a8a9a;
    --danger: #ff4d6d;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ─── Background grid ─── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,200,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,200,255,0.03) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
    z-index: 0;
  }

  /* ─── Radial glow blobs ─── */
  .blob {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.18;
  }
  .blob-1 { width: 600px; height: 600px; background: var(--accent3); top: -200px; right: -200px; }
  .blob-2 { width: 500px; height: 500px; background: var(--accent); bottom: -150px; left: -150px; }
  .blob-3 { width: 300px; height: 300px; background: var(--accent2); top: 50%; left: 50%; transform: translate(-50%,-50%); opacity: 0.08; }

  /* ─── Layout wrapper ─── */
  .wrapper { position: relative; z-index: 1; max-width: 900px; margin: 0 auto; padding: 0 24px; }

  /* ─── Header ─── */
  header {
    padding: 80px 0 60px;
    text-align: center;
    animation: fadeUp 0.8s ease both;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    border: 1px solid var(--border);
    border-radius: 100px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 28px;
    background: rgba(0,200,255,0.05);
  }
  .badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--accent2);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent2);
    animation: pulse 2s infinite;
  }

  h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(42px, 8vw, 72px);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #fff 30%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 16px;
  }

  .subtitle {
    font-family: 'DM Mono', monospace;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.08em;
    margin-bottom: 32px;
  }

  .tagline {
    font-size: 16px;
    color: #8eacba;
    max-width: 480px;
    margin: 0 auto 40px;
    line-height: 1.7;
  }

  /* ─── Stats row ─── */
  .stats {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
    animation: fadeUp 0.9s 0.2s ease both;
  }
  .stat {
    text-align: center;
  }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 36px;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    text-shadow: 0 0 20px rgba(0,200,255,0.4);
  }
  .stat-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ─── Divider ─── */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border) 30%, var(--border) 70%, transparent);
    margin: 60px 0;
  }

  /* ─── Section heading ─── */
  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent2);
    margin-bottom: 40px;
    display: flex;
    align-items: center;
    gap: 12px;
    animation: fadeUp 0.8s 0.3s ease both;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ─── Certificate cards ─── */
  .certs-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .cert-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px 32px;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    animation: fadeUp 0.7s ease both;
    cursor: default;
  }

  .cert-card::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }

  .cert-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 60px -10px rgba(0,200,255,0.15);
  }

  .cert-card.tryhackme { --card-accent: #ff6b6b; }
  .cert-card.cisco     { --card-accent: #00c8ff; }
  .cert-card.cybrary   { --card-accent: #00ff9f; }

  .cert-card:hover { border-color: var(--card-accent, var(--accent)); }

  .cert-card::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--card-accent, var(--accent));
    border-radius: 0 2px 2px 0;
    box-shadow: 0 0 12px var(--card-accent, var(--accent));
  }

  .issuer-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
  }

  .cert-info { min-width: 0; }

  .cert-name {
    font-family: 'Syne', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 4px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cert-issuer {
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 6px;
  }

  .cert-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: 1px solid;
  }
  .tag-blue  { color: var(--accent);  border-color: rgba(0,200,255,0.25);  background: rgba(0,200,255,0.06); }
  .tag-green { color: var(--accent2); border-color: rgba(0,255,159,0.25);  background: rgba(0,255,159,0.06); }
  .tag-purple{ color: var(--accent3); border-color: rgba(123,97,255,0.25); background: rgba(123,97,255,0.06); }
  .tag-red   { color: #ff6b6b;        border-color: rgba(255,107,107,0.25);background: rgba(255,107,107,0.06); }

  .cert-meta {
    text-align: right;
    flex-shrink: 0;
  }
  .cert-date {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }
  .cert-verify {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--card-accent, var(--accent));
    margin-top: 6px;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
  }
  .cert-verify::before {
    content: '✓';
    font-size: 10px;
  }

  /* ─── Skills section ─── */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 12px;
    animation: fadeUp 0.8s 0.4s ease both;
  }

  .skill-pill {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 16px;
    text-align: center;
    transition: border-color 0.25s, transform 0.25s;
  }
  .skill-pill:hover {
    border-color: rgba(0,200,255,0.3);
    transform: translateY(-2px);
  }
  .skill-icon { font-size: 22px; display: block; margin-bottom: 8px; }
  .skill-name {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ─── Footer ─── */
  footer {
    text-align: center;
    padding: 60px 0 80px;
    animation: fadeUp 0.8s 0.5s ease both;
  }
  .footer-name {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .footer-note {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: rgba(106,138,154,0.5);
    letter-spacing: 0.06em;
  }

  /* ─── Animations ─── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ─── Stagger ─── */
  .cert-card:nth-child(1) { animation-delay: 0.3s; }
  .cert-card:nth-child(2) { animation-delay: 0.4s; }
  .cert-card:nth-child(3) { animation-delay: 0.5s; }
  .cert-card:nth-child(4) { animation-delay: 0.6s; }
  .cert-card:nth-child(5) { animation-delay: 0.7s; }

  /* ─── Responsive ─── */
  @media (max-width: 600px) {
    .cert-card { grid-template-columns: auto 1fr; }
    .cert-meta { display: none; }
    .stats { gap: 24px; }
  }

  /* ─── Certificate Images ─── */
  .cert-images-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
    gap: 20px;
  }

  .cert-img-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
    animation: fadeUp 0.8s 0.4s ease both;
  }
  .cert-img-card:hover {
    border-color: rgba(0,200,255,0.3);
    transform: translateY(-4px);
    box-shadow: 0 24px 60px -10px rgba(0,200,255,0.12);
  }
  .cert-img-card img {
    width: 100%;
    display: block;
    border-radius: 0 0 12px 12px;
  }
  .cert-img-label {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--border);
  }
  .cert-img-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 6px currentColor;
  }

  @media (max-width: 500px) {
    .cert-images-grid { grid-template-columns: 1fr; }
  }

</style>
</head>
